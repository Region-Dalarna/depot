name: Deploy

on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: [self-hosted, "{{runner_label}}"]
    steps:
      - uses: actions/checkout@v4

      - name: Render
        run: quarto render

      - name: Publicera
        run: /usr/local/bin/rapport_deploy_repo.sh "$(pwd)/_site" "{{github_repo}}"